# =============================================
# StudyBuddy Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# --- Application ---
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:8000

# --- Database ---
# SQLite (development)
# DATABASE_URL=sqlite:///./studybuddy.db
# PostgreSQL (production — use Render's Internal Database URL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/studybuddy

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- OpenRouter (AI) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=10
